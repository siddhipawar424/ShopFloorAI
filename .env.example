# ===========================
# Root .env Configuration
# ===========================

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Main Database (assistant) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assistant
DB_USER=postgres
DB_PASSWORD=your_password_here

# --- CSV Embeddings Database ---
CSV_DB_HOST=localhost
CSV_DB_PORT=5432
CSV_DB_NAME=csv_embeddings
CSV_DB_USER=postgres
CSV_DB_PASSWORD=your_password_here

# --- Cycle Time Embeddings Database ---
CYCLETIME_DB_HOST=localhost
CYCLETIME_DB_PORT=5432
CYCLETIME_DB_NAME=cycle_time_embeddings
CYCLETIME_DB_USER=postgres
CYCLETIME_DB_PASSWORD=your_password_here

# --- CNC Embeddings Database ---
CNC_DB_HOST=localhost
CNC_DB_PORT=5432
CNC_DB_NAME=cnc_embeddings
CNC_DB_USER=postgres
CNC_DB_PASSWORD=your_password_here

# --- Session / Machine Status Database ---
SESSION_DB_HOST=localhost
SESSION_DB_PORT=5432
SESSION_DB_NAME=machinestatus
SESSION_DB_USER=postgres
SESSION_DB_PASSWORD=your_password_here

# --- Observer Database ---
OBSERVER_DB_HOST=localhost
OBSERVER_DB_PORT=5432
OBSERVER_DB_NAME=observer
OBSERVER_DB_USER=postgres
OBSERVER_DB_PASSWORD=your_password_here

# --- Hugging Face (optional) ---
HF_ENDPOINT=https://huggingface.co
