# ===========================
# Backend .env Configuration
# ===========================

PORT=5000
CORS_ORIGINS=*

# --- Auth Login Database ---
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=login
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=your_password_here

# --- Auth Registration Database ---
AUTH_REG_DB_HOST=localhost
AUTH_REG_DB_PORT=5432
AUTH_REG_DB_NAME=registration
AUTH_REG_DB_USER=postgres
AUTH_REG_DB_PASSWORD=your_password_here

# --- JWT Configuration ---
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Machine Status Database ---
MACHINE_DB_HOST=localhost
MACHINE_DB_PORT=5432
MACHINE_DB_NAME=machinestatus
MACHINE_DB_USER=postgres
MACHINE_DB_PASSWORD=your_password_here

# --- Observer Database ---
OBSERVER_DB_HOST=localhost
OBSERVER_DB_PORT=5432
OBSERVER_DB_NAME=observer
OBSERVER_DB_USER=postgres
OBSERVER_DB_PASSWORD=your_password_here
